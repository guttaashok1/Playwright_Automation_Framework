# ============================================================
# Playwright Automation Framework - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Application Under Test -----
BASE_URL=https://your-app.example.com
API_BASE_URL=https://api.your-app.example.com

# ----- Test Environment (dev | staging | prod) -----
ENVIRONMENT=staging

# ----- Browser Config -----
BROWSER=chromium                  # chromium | firefox | webkit
HEADLESS=true
SLOW_MO=0                         # milliseconds between actions (useful for debugging)
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# ----- Test Credentials -----
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=your_test_password

# ----- Azure DevOps (ADO) -----
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PROJECT=YourProject
ADO_PAT=your_ado_personal_access_token
ADO_TEST_PLAN_ID=123              # Optional: default test plan ID

# ----- Confluence -----
CONFLUENCE_URL=https://your-org.atlassian.net
CONFLUENCE_USERNAME=your_email@example.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_SPACE_KEY=QA           # Confluence space key for test docs

# ----- GitHub -----
GITHUB_TOKEN=your_github_token    # For PR/checks integration

# ----- Slack Notifications (optional) -----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#test-results

# ----- MS Teams Notifications (optional) -----
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx/IncomingWebhook/yyy/zzz

# ----- Self-Healing Locators -----
SELF_HEALING_ENABLED=true
SELF_HEALING_PROBE_TIMEOUT_MS=3000   # ms to try each fallback selector

# ----- Visual Regression -----
VISUAL_REGRESSION_ENABLED=true
VISUAL_THRESHOLD=0.02                # 2% pixel-diff tolerance (0.0–1.0)

# ----- Allure Reporting (optional) -----
ALLURE_RESULTS_DIR=reports/allure-results
